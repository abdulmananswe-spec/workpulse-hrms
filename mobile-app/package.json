{
  "name": "workpulse-hrms-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "description": "WorkPulse HRMS Mobile App — Developed by Abdul Manan",
  "author": "Abdul Manan",
  "license": "MIT",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:android:production": "npx eas-cli build --platform android --profile production",
    "prebuild:android": "expo prebuild --platform android --clean",
    "android:assembleDebug": "cd android && gradlew.bat assembleDebug",
    "android:assembleDebug:ci": "cd android && chmod +x gradlew && ./gradlew assembleDebug --no-daemon",
    "android:assembleRelease": "cd android && gradlew.bat assembleRelease",
    "android:bundleRelease": "cd android && gradlew.bat bundleRelease",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "2.49.8",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "nativewind": "^4.2.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.78.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react-dom": "19.1.0"
  }
}
