# =============================================================================
# Employee Attendance Management System — Environment Variables
# Copy this file to each sub-project as needed:
#   mobile-app/.env
#   admin-panel/.env.local
#   database/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for mobile-app and admin-panel)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Expo uses EXPO_PUBLIC_ prefix (same values as above)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Admin Panel
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database / Supabase CLI (database folder only — never commit real values)
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_DB_PASSWORD=your-database-password
